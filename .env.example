# --- Model provider -------------------------------------------------------
# The agent runs against a deterministic MOCK provider by default, so the app
# works with zero setup, no network, and no API keys. Switch only if you want
# a real model.
AI_PROVIDER=mock            # mock (default) | anthropic | openai | bedrock

# anthropic  (AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # fast + cheap, great tool use (default)
# ANTHROPIC_MODEL=claude-opus-4-8     # higher ceiling for answer quality

# openai     (AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# bedrock    (AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...        # if using temporary credentials
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Gateway (optional) ---------------------------------------------------
# Route the anthropic/openai providers through a gateway by setting a base URL
# (applied as the provider baseURL). Leave unset to call the provider directly.
#
# Cloudflare AI Gateway + Anthropic (this project's setup):
#   1. Cloudflare dashboard -> AI -> AI Gateway -> Create Gateway (note its name).
#   2. Your base URL is:
#        https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/anthropic
#      The Anthropic SDK appends `/messages`, so add a trailing `/v1`:
# AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/anthropic/v1
#   3. Still set ANTHROPIC_API_KEY above — the gateway forwards it upstream.
#   4. (Optional) If you make the gateway "Authenticated" (Settings -> require
#      a token), create a gateway token and set AI_GATEWAY_TOKEN below so
#      requests carry `cf-aig-authorization: Bearer <token>`.
# AI_GATEWAY_TOKEN=<cloudflare-ai-gateway-token>
#
#   5. Caching + rate limiting (stretch). Both are gateway features:
#      - Caching: enable it on the gateway (dashboard -> gateway -> Settings ->
#        Caching, or the API field `cache_ttl`). Per-request, our app sends
#        `cf-aig-cache-ttl` when AI_GATEWAY_CACHE_TTL is set (seconds, 60..2592000),
#        and `cf-aig-skip-cache` when AI_GATEWAY_SKIP_CACHE=true. The response
#        header `cf-aig-cache-status` reports HIT/MISS.
#      - Rate limiting: set it on the gateway (Settings -> Rate limiting, or the
#        API fields `rate_limiting_interval` + `rate_limiting_limit`). It's
#        per-gateway and returns 429 when exceeded; no app change needed.
#      Every request is tagged `cf-aig-metadata: {workspaceId, role}` so the
#      gateway's analytics/caching/limit views can be segmented per tenant.
# AI_GATEWAY_CACHE_TTL=3600
# AI_GATEWAY_SKIP_CACHE=false
#
# Vercel AI Gateway alternative:
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# --- Database -------------------------------------------------------------
# Directory for the file-backed PGlite database. The db:seed process and the
# `next dev` process share this directory so seeded data is visible in the app.
PGLITE_DIR=./.pglite
